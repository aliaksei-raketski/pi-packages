{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "emitDeclarationOnly": true,
    "types": ["node"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*.ts",
    "package.json",
    "extensions/**/*.ts",
    "skills/**/*.ts",
    "prompts/**/*.ts",
    "themes/**/*.ts",
    "scripts/**/*.ts",
    "*.ts"
  ],
  "references": [],
  "exclude": [
    "dist",
    "out-tsc",
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.test.tsx",
    "**/*.spec.tsx",
    "**/*.test.js",
    "**/*.spec.js",
    "**/*.test.jsx",
    "**/*.spec.jsx",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx",
    "extensions/**/*.test.ts",
    "extensions/**/*.spec.ts",
    "extensions/**/*.test.tsx",
    "extensions/**/*.spec.tsx",
    "extensions/**/*.test.js",
    "extensions/**/*.spec.js",
    "extensions/**/*.test.jsx",
    "extensions/**/*.spec.jsx"
  ]
}
