{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"types": ["node"],
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"allowImportingTsExtensions": true
	},
	"include": ["packages/**/*.ts"]
}
